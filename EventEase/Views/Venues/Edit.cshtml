@model EventEase.Models.Venue

@{
    ViewData["Title"] = "Edit Venue";
}
<div class="container mt-4">
    <h1>Edit Venue</h1>

    <form asp-action="Edit" method="post" enctype="multipart/form-data">
        <input type="hidden" asp-for="VenueId" />
        <input type="hidden" asp-for="ImageURL" />
        <div class="mb-3">
            <label class="form-label">Venue Name</label>
            <input asp-for="VenueName" class="form-control" />
        </div>

        <div class="mb-3">
            <label class="form-label">Location</label>
            <input asp-for="Location" class="form-control" />
        </div>

        <div class="mb-3">
            <label class="form-label">Capacity</label>
            <input asp-for="Capacity" class="form-control" />
        </div>

        <div class="mb-3">
            <label class="form-label">Available</label>
            <select asp-for="Availability" class="form-select">
                <option value="true">Yes</option>
                <option value="false">No</option>
            </select>
        </div>

        <div class="mb-3">
            <label class="form-label">Venue Image</label>
            @if (!string.IsNullOrEmpty(Model.ImageURL))
            {
                <div class="mb-2">
                    <img src="@Model.ImageURL" style="max-height: 150px;" class="img-thumbnail" />
                    <p class="text-muted">Current image — upload a new one to replace it</p>
                </div>
            }
            <input asp-for="ImageFile" type="file" class="form-control" accept="image/*" />
        </div>
        <button type="submit" class="btn btn-primary">Save</button>
        <a asp-action="Index" class="btn btn-secondary">Back to List</a>
    </form>
</div>