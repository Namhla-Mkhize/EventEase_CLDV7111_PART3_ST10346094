@model IEnumerable<EventEase.Models.Event>

@{
    ViewData["Title"] = "Events";
}
<div class="container mt-4">
 <div class="d-flex justify-content-between align-items-center mb-3">
    <h1>Events</h1>
    <a asp-action="Create" class="btn btn-primary">Create New Event</a>
 </div> 

    <form asp-action="Index" method="get" class="mb-3">
        <div class="row g-2">
            <div class="col-md-3">
                <input type="text" name="searchString" value="@ViewBag.SearchString" 
                       class="form-control" placeholder="Search by name or venue..." />
            </div>
            <div class="col-md-3">
                <select name="eventTypeId" class="form-select">
                    <option value="">-- All Event Types --</option>
                    @foreach (var et in ViewBag.EventTypes as List<EventEase.Models.EventType>)
                    {
                        if (ViewBag.SelectedEventType != null && ViewBag.SelectedEventType == et.EventTypeId)
                        {
                            <option value="@et.EventTypeId" selected>
                                @et.EventTypeName
                            </option>
                        }
                        else
                        {
                            <option value="@et.EventTypeId">
                                @et.EventTypeName
                            </option>
                        }
                    }5
                </select>
            </div>
            <div class="col-md-2">
                <input type="date" name="startDate" value="@ViewBag.StartDate" class="form-control" />
            </div>
            <div class="col-md-2">
                <input type="date" name="endDate" value="@ViewBag.EndDate" class="form-control" />
            </div>
            <div class="col-md-2">
                <button type="submit" class="btn btn-outline-secondary w-100">Filter</button>
                <a asp-action="Index" class="btn btn-outline-danger w-100 mt-1">Clear</a>
            </div>
        </div>
    </form>

    @if (TempData["ErrorMessage"] != null)
    {
        <div class="alert alert-danger">@TempData["ErrorMessage"]</div>
    }

<table class="table table-striped table-hover table-bordered">
    <thead class="table-dark">
        <tr>
            <th>Event Name</th>
            <th>Date</th>
            <th>Description</th>
            <th>Venue</th>
            <th>Event Type</th>
            <th>Actions</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var newEvent in Model)
        {
            <tr>
                <td>@newEvent.EventName</td>
                <td>@newEvent.EventDate?.ToString("dd MMM yyyy")</td>
                <td>@newEvent.Description</td>
                <td>@newEvent.Venue?.VenueName</td>
                <td>@newEvent.EventType?.EventTypeName</td>
                <td>
                    <a asp-action="Edit" asp-route-id="@newEvent.EventId" class="btn btn-sm btn-warning">Edit</a>
                    <a asp-action="Delete" asp-route-id="@newEvent.EventId" class="btn btn-sm btn-danger">Delete</a>
                </td>
            </tr>
        }
    </tbody>
</table>
</div>