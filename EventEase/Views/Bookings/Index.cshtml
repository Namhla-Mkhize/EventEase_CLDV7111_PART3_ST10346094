@model IEnumerable<EventEase.Models.Booking>

@{
    ViewData["Title"] = "Bookings";
}
<div class="container mt-4">
    <div class="d-flex justify-content-between align-items-center mb-3">
        <h1>Bookings</h1>
        <a asp-action="Create" class="btn btn-primary">Create New Booking</a>
    </div>

    <form asp-action="Index" method="get" class="mb-3">
        <div class="row g-2">
            <div class="col-md-3">
                <input type="text" name="searchString" value="@ViewBag.SearchString"
                       class="form-control" placeholder="Search by ID, event or venue..." />
            </div>
            <div class="col-md-2">
                <select name="eventTypeId" class="form-select">
                    <option value="">-- All Event Types --</option>
                    @foreach (var et in ViewBag.EventTypes as List<EventEase.Models.EventType>)
                    {
                        <option value="@et.EventTypeId">@et.EventTypeName</option>
                    }
                </select>
            </div>
            <div class="col-md-2">
                <input type="date" name="startDate" value="@ViewBag.StartDate" class="form-control" placeholder="Start Date" />
            </div>
            <div class="col-md-2">
                <input type="date" name="endDate" value="@ViewBag.EndDate" class="form-control" placeholder="End Date" />
            </div>
            <div class="col-md-1">
                <select name="availability" class="form-select">
                    <option value="">All</option>
                    <option value="true">Available</option>
                    <option value="false">Unavailable</option>
                </select>
            </div>
            <div class="col-md-2">
                <button type="submit" class="btn btn-outline-secondary w-100">Filter</button>
                <a asp-action="Index" class="btn btn-outline-danger w-100 mt-1">Clear</a>
            </div>
        </div>
    </form>

    <table class="table table-striped table-hover table-bordered">
        <thead class="table-dark">
            <tr>
                <th>Booking ID</th>
                <th>Venue Name</th>
                <th>Venue Location</th>
                <th>Available</th>
                <th>Event Name</th>
                <th>Event Type</th>
                <th>Event Date</th>
                <th>Booking Date</th>
                <th>Actions</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var booking in Model)
            {
                <tr>
                    <td>@booking.BookingId</td>
                    <td>@booking.Venue?.VenueName</td>
                    <td>@booking.Venue?.Location</td>
                    <td>@(booking.Venue?.Availability == true ? "Yes" : "No")</td>
                    <td>@booking.Event?.EventName</td>
                    <td>@booking.Event?.EventType?.EventTypeName</td>
                    <td>@booking.Event?.EventDate?.ToString("dd MMM yyyy")</td>
                    <td>@booking.BookingDate.ToString("dd MMM yyyy")</td>
                    <td>
                        <a asp-action="Edit" asp-route-id="@booking.BookingId" class="btn btn-sm btn-warning">Edit</a>
                        <a asp-action="Delete" asp-route-id="@booking.BookingId" class="btn btn-sm btn-danger">Delete</a>
                    </td>
                </tr>
            }
        </tbody>
    </table>
</div>